generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── MÓDULO: AUTH ────────────────────────────────────────────────────────────

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  rol       String   @default("VENDEDOR") // ADMIN | VENDEDOR
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  ventas    Venta[]
}

// ─── MÓDULO: CONFIG ───────────────────────────────────────────────────────────

model Operario {
  id        Int       @id @default(autoincrement())
  nombre    String
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  pilados   Pilado[]
}

model Parametro {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String
}

// ─── MÓDULO: STOCK ────────────────────────────────────────────────────────────

model Producto {
  id            Int               @id @default(autoincrement())
  nombre        String
  unidad        String
  stockActual   Float             @default(0)
  stockLocal    Float             @default(0)
  stockMinimo   Float             @default(0)
  ubicacion     String            @default("piladora")
  categoria     String            @default("grano")
  createdAt     DateTime          @default(now())
  movimientos   StockMovimiento[]
  detallesVenta DetalleVenta[]
}

model StockMovimiento {
  id         Int      @id @default(autoincrement())
  productoId Int
  tipo       String
  cantidad   Float
  motivo     String?
  createdAt  DateTime @default(now())
  producto   Producto @relation(fields: [productoId], references: [id])
}

// ─── MÓDULO: VENTA ────────────────────────────────────────────────────────────

model Venta {
  id         Int            @id @default(autoincrement())
  total      Float
  metodoPago String
  nota       String?
  cliente    String?
  ubicacion  String         @default("piladora")
  ingresoId  Int?
  usuarioId  Int?
  createdAt  DateTime       @default(now())
  detalles   DetalleVenta[]
  usuario    Usuario?       @relation(fields: [usuarioId], references: [id])
}

model DetalleVenta {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Float
  precioUnit Float
  subtotal   Float
  venta      Venta    @relation(fields: [ventaId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])
}

// ─── MÓDULO: PILAR ────────────────────────────────────────────────────────────

model Pilado {
  id               Int      @id @default(autoincrement())
  operarioId       Int
  qqEntrada        Float
  tandas           Int      @default(0)
  sacosPilado      Float    @default(0)
  sacosSubproducto Float    @default(0)
  horaInicio       String   @default("")
  horaFin          String   @default("")
  horas            Float    @default(0)
  rendimiento      Float    @default(0)
  velocidad        Float    @default(0)
  costoEstimado    Float    @default(0)
  egresoId         Int?
  nota             String?
  createdAt        DateTime @default(now())
  operario         Operario @relation(fields: [operarioId], references: [id])
}

// ─── MÓDULO: DINERO ───────────────────────────────────────────────────────────

model Ingreso {
  id          Int      @id @default(autoincrement())
  monto       Float
  descripcion String
  categoria   String?
  ventaId     Int?
  createdAt   DateTime @default(now())
}

model Egreso {
  id          Int      @id @default(autoincrement())
  monto       Float
  descripcion String
  categoria   String?
  createdAt   DateTime @default(now())
}
