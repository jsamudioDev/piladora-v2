generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── MÓDULO: AUTH ────────────────────────────────────────────────────────────

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  rol       String   @default("VENDEDOR") // ADMIN | OPERARIO | VENDEDOR
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  ventas    Venta[]
}

// ─── MÓDULO: CONFIG ───────────────────────────────────────────────────────────

model Operario {
  id        Int              @id @default(autoincrement())
  nombre    String
  activo    Boolean          @default(true)
  createdAt DateTime         @default(now())
  pilados   Pilado[]
  secados   SecadoPulidura[]
}

model Parametro {
  id          Int     @id @default(autoincrement())
  clave       String  @unique
  valor       String
  descripcion String?
}

// ─── MÓDULO: STOCK ────────────────────────────────────────────────────────────

model Producto {
  id                  Int                 @id @default(autoincrement())
  nombre              String
  unidad              String
  precio              Float               @default(0)
  stockActual         Float               @default(0)   // stock en piladora
  stockLocal          Float               @default(0)   // stock en local
  stockMinimo         Float               @default(0)
  ubicacion           String              @default("piladora")
  categoria           String              @default("grano")
  activo              Boolean             @default(true)
  createdAt           DateTime            @default(now())
  movimientos         StockMovimiento[]
  detallesVenta       DetalleVenta[]
  devolucionesDetalle DetalleDevolucion[]
  traspasos           Traspaso[]
}

model StockMovimiento {
  id         Int      @id @default(autoincrement())
  productoId Int
  tipo       String   // ENTRADA | SALIDA
  cantidad   Float
  motivo     String?
  ubicacion  String?  // piladora | local — stock afectado por este movimiento
  createdAt  DateTime @default(now())
  producto   Producto @relation(fields: [productoId], references: [id])
}

// ─── MÓDULO: VENTA ────────────────────────────────────────────────────────────

model Venta {
  id               Int            @id @default(autoincrement())
  total            Float
  metodoPago       String         // EFECTIVO | YAPPY | TRANSFERENCIA | CHEQUE | CREDITO
  nota             String?
  cliente          String?
  ubicacion        String         @default("piladora")
  ingresoId        Int?
  creditoId        Int?           @unique
  usuarioId        Int?
  // ─── Facturación ─────────────────────────────────────────────────────────────
  facturaNum       Int?           @unique  // número correlativo de factura
  clienteRuc       String?
  clienteDireccion String?
  aplicaITBMS      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  detalles         DetalleVenta[]
  usuario          Usuario?       @relation(fields: [usuarioId], references: [id])
}

model DetalleVenta {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Float
  precioUnit Float
  subtotal   Float
  venta      Venta    @relation(fields: [ventaId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])
}

// ─── MÓDULO: PILAR ────────────────────────────────────────────────────────────

model Pilado {
  id               Int      @id @default(autoincrement())
  operarioId       Int
  qqEntrada        Float
  tandas           Int      @default(0)
  sacosPilado      Float    @default(0)
  sacosSubproducto Float    @default(0)
  horaInicio       String   @default("")
  horaFin          String   @default("")
  horas            Float    @default(0)
  rendimiento      Float    @default(0)
  velocidad        Float    @default(0)
  costoEstimado    Float    @default(0)
  egresoId         Int?
  nota             String?
  createdAt        DateTime @default(now())
  operario         Operario @relation(fields: [operarioId], references: [id])
}

// ─── MÓDULO: PULIDURA ────────────────────────────────────────────────────────

model SecadoPulidura {
  id           Int      @id @default(autoincrement())
  operarioId   Int
  sacosHumedos Float
  sacosSecs    Float    @default(0)
  pesoHumedo   Float    @default(63)
  pesoSeco     Float    @default(50)
  rendimiento  Float    @default(0)
  lbsHumedas   Float    @default(0)
  lbsSecas     Float    @default(0)
  nota         String?
  usuarioId    Int?
  createdAt    DateTime @default(now())
  operario     Operario @relation(fields: [operarioId], references: [id])
}

// ─── MÓDULO: CRÉDITOS ────────────────────────────────────────────────────────

model Credito {
  id               Int       @id @default(autoincrement())
  clienteNombre    String
  clienteTel       String?
  clienteCedula    String?                 // Cédula, pasaporte o RUC del cliente
  montoTotal       Float
  montoPagado      Float     @default(0)
  saldo            Float
  estado           String    @default("PENDIENTE") // PENDIENTE | PAGADO | VENCIDO
  nota             String?
  ventaId          Int?      @unique       // ID de la venta que originó el crédito
  fechaVencimiento DateTime?              // Fecha límite de pago acordada
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  abonos           Abono[]
}

model Abono {
  id         Int      @id @default(autoincrement())
  creditoId  Int
  monto      Float
  metodoPago String   @default("EFECTIVO") // EFECTIVO | YAPPY | TRANSFERENCIA | CHEQUE
  referencia String?
  nota       String?
  usuarioId  Int?
  createdAt  DateTime @default(now())
  credito    Credito  @relation(fields: [creditoId], references: [id])
}

// ─── MÓDULO: DINERO ───────────────────────────────────────────────────────────

model Ingreso {
  id          Int      @id @default(autoincrement())
  monto       Float
  descripcion String
  categoria   String?
  ventaId     Int?
  createdAt   DateTime @default(now())
}

model Egreso {
  id          Int      @id @default(autoincrement())
  monto       Float
  descripcion String
  categoria   String?
  createdAt   DateTime @default(now())
}

// ─── MÓDULO: DEVOLUCIONES ────────────────────────────────────────────────────

model Devolucion {
  id            Int                 @id @default(autoincrement())
  ventaId       Int
  totalDevuelto Float
  motivo        String
  createdAt     DateTime            @default(now())
  detalles      DetalleDevolucion[]
}

model DetalleDevolucion {
  id           Int        @id @default(autoincrement())
  devolucionId Int
  productoId   Int
  cantidad     Float
  precioUnit   Float
  ubicacion    String     @default("piladora")
  devolucion   Devolucion @relation(fields: [devolucionId], references: [id])
  producto     Producto   @relation(fields: [productoId], references: [id])
}

// ─── MÓDULO: BITÁCORA ────────────────────────────────────────────────────────

model Bitacora {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  nombre    String?
  modulo    String
  accion    String
  detalle   String   @db.Text
  ip        String?
  createdAt DateTime @default(now())

  @@index([modulo])
  @@index([usuarioId])
  @@index([createdAt])
}

// ─── MÓDULO: TRASPASOS ────────────────────────────────────────────────────────

model Traspaso {
  id         Int      @id @default(autoincrement())
  productoId Int
  cantidad   Float
  origen     String   // piladora | local
  destino    String   // piladora | local
  motivo     String?
  createdAt  DateTime @default(now())
  producto   Producto @relation(fields: [productoId], references: [id])
}
